{% extends 'base.html.twig' %}

{% block title %}Kategorie{% endblock %}

{% block body %}
<div class="card">
    <h1>Kategorie</h1>
    <p><a href="{{ path('categories_new') }}" class="btn btn-primary">Dodaj kategorię</a></p>
    <table>
        <thead><tr><th>ID</th><th>Nazwa</th><th>Opis</th><th>Akcje</th></tr></thead>
        <tbody>
            {% for category in categories %}
            <tr>
                <td>{{ category.id }}</td>
                <td>{{ category.name }}</td>
                <td>{{ category.description|default('—') }}</td>
                <td class="actions">
                    <a href="{{ path('categories_show', {id: category.id}) }}" class="btn btn-secondary">Pokaż</a>
                    <a href="{{ path('categories_edit', {id: category.id}) }}" class="btn btn-primary">Edytuj</a>
                    <form method="post" action="{{ path('categories_delete', {id: category.id}) }}" style="display:inline" onsubmit="return confirm('Usunąć?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                        <button type="submit" class="btn btn-danger">Usuń</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4">Brak kategorii.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
